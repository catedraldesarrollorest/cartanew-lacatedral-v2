{
  "version": 2,
  "buildCommand": "cp index.html /vercel/output/index.html && cp -r www /vercel/output/www 2>/dev/null || true",
  "name": "lacatedral-backoffice",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/public/admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/public/admin/$1"
    }
  ]
}
