{
  "version": 2,
  "buildCommand": "",
  "name": "lacatedral-backoffice",
  "public": true,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/public/admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/public/admin/$1"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/(?!api|admin|public)(.*)$",
      "dest": "/index.html"
    }
  ]
}
